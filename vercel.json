{
  "version": 2,
  "routes": [
    { "src": "/api/chat",      "dest": "/api/chat.js" },
    { "src": "/api/salah",     "dest": "/api/chat.js" },
    { "src": "/api/(.*)",      "dest": "/api/$1" },
    { "src": "/pricing",       "dest": "/pricing.html" },
    { "src": "/",              "dest": "/index.html" },
    { "src": "/(.*)",          "dest": "/$1" }
  ]
}
